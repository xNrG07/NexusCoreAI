{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "functions": {
    "api/gemini.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/impressum",
      "destination": "/impressum.html",
      "permanent": false
    },
    {
      "source": "/datenschutz",
      "destination": "/datenschutz.html",
      "permanent": false
    },
    {
      "source": "/cookies",
      "destination": "/cookies.html",
      "permanent": false
    }
  ]
}
